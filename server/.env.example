# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/gujaratjobs

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# Client (comma-separated list of allowed origins)
CLIENT_URL=http://localhost:5173

# Cross-site cookies (set true in production behind HTTPS, e.g. Render)
COOKIE_SECURE=false

# Auto-run general scraper on startup + every 6h (set true in prod when ready)
ENABLE_SCRAPER=false

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=GujaratJobs <noreply@gujaratjobs.in>

# Apify (for job scraping)
APIFY_API_TOKEN=your_apify_api_token_here

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin
ADMIN_EMAIL=admin@gujaratjobs.in
ADMIN_PASSWORD=Admin@123456
